# Environment
NODE_ENV=production

# Site
NEXT_PUBLIC_SITE_URL=https://sufyanahmed.tech

# Contact form — Hostinger email (hello@sufyanahmed.tech)
# Hostinger defaults: SMTP = smtp.hostinger.com | IMAP = imap.hostinger.com (for reading mail in apps)
# The contact form only needs SMTP (sending). Add these in Coolify — do not commit real passwords.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@sufyanahmed.tech
SMTP_PASS=
CONTACT_TO_EMAIL=hello@sufyanahmed.tech

# Coolify deployment (do not commit real values — use Cursor secrets or local .env)
# COOLIFY_URL=https://your-coolify-panel.example.com
# COOLIFY_TOKEN=your-api-token-with-deploy-permission
# COOLIFY_PROJECT_UUID=
# COOLIFY_SERVER_UUID=
# COOLIFY_APP_UUID=
# APP_DOMAIN=https://sufyanahmed.tech

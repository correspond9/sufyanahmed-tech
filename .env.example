# Environment
NODE_ENV=production

# Site
NEXT_PUBLIC_SITE_URL=https://sufyanahmed.tech

# Contact form — Hostinger email (hello@sufyanahmed.tech)
#
# Hostinger server settings (from hPanel → Emails → Manage → Configuration):
#   SMTP (sending — used by contact form): smtp.hostinger.com  port 465  SSL/TLS
#   IMAP (reading in mail apps only):     imap.hostinger.com  port 993  SSL/TLS
#   POP3 (not recommended):               pop.hostinger.com   port 995  SSL/TLS
#
# Add these in Coolify → sufyanahmed-tech → Environment Variables.
# Do NOT commit your real email password.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@sufyanahmed.tech
SMTP_PASS=
CONTACT_TO_EMAIL=hello@sufyanahmed.tech

